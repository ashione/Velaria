{
  "name": "velaria-electron-prototype",
  "version": "0.1.0",
  "description": "Velaria desktop prototype with Electron + Python sidecar",
  "main": "dist/electron/main/main.js",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build && node ./scripts/fix-renderer-paths.mjs",
    "start": "npm run build:electron && npm run build:renderer && electron .",
    "build:sidecar": "bash ./scripts/build-sidecar-macos.sh",
    "dist:mac": "npm run build:electron && npm run build:renderer && electron-builder --config electron-builder.yml --mac dmg",
    "package:mac": "bash ./scripts/package-macos.sh"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
